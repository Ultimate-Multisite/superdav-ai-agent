exports[`ProviderSelector snapshots matches snapshot with no providers 1`] = `"<div class="ai-agent-provider-selector "><div data-size="default"><label>Provider</label><select data-label="Provider"><option value="">(no providers)</option></select></div><div data-size="default"><label>Model</label><select data-label="Model"><option value="">(default)</option></select></div></div>"`;
