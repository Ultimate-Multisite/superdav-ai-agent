{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "meta": {
    "title": "AI Agent",
    "description": "Agentic AI assistant for WordPress — chat, call tools, run automations, and manage your site with any AI provider.",
    "author": "Ultimate-Multisite",
    "categories": ["AI", "Automation", "Chat"]
  },
  "landingPage": "/wp-admin/admin.php?page=gratis-ai-agent",
  "login": {
    "username": "admin",
    "password": "password"
  },
  "preferredVersions": {
    "php": "8.2",
    "wp": "nightly"
  },
  "features": {
    "networking": true
  },
  "steps": [
    {
      "step": "defineWpConfigConsts",
      "consts": {
        "WP_DEBUG": true,
        "WP_DEBUG_LOG": true,
        "WP_DEBUG_DISPLAY": true,
        "SCRIPT_DEBUG": true
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "url",
        "url": "https://github.com/Ultimate-Multisite/gratis-ai-agent/releases/latest/download/gratis-ai-agent.zip",
        "caption": "Downloading AI Agent..."
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "url",
        "url": "https://github.com/Ultimate-Multisite/ai-provider-for-anthropic-max/releases/latest/download/ai-provider-for-anthropic-max.zip",
        "caption": "Downloading AI Provider for Anthropic Max..."
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "url",
        "url": "https://github.com/Ultimate-Multisite/ultimate-ai-connector-compatible-endpoints/releases/download/latest/ultimate-ai-connector-compatible-endpoints.zip",
        "caption": "Downloading AI Provider for Any Compatible Endpoint..."
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "setSiteOptions",
      "options": {
        "blogname": "AI Agent Demo",
        "blogdescription": "WordPress AI Agent — instant demo"
      }
    }
  ]
}
