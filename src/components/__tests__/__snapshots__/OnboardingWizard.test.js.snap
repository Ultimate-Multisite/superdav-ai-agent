// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`OnboardingWizard snapshots matches snapshot on step 0 (Welcome) 1`] = `"<div class="gratis-ai-agent-wizard"><div class="gratis-ai-agent-wizard-header"><h2>Welcome to Gratis AI Agent</h2><div class="gratis-ai-agent-wizard-progress"><span class="gratis-ai-agent-wizard-dot is-active "></span><span class="gratis-ai-agent-wizard-dot  "></span><span class="gratis-ai-agent-wizard-dot  "></span><span class="gratis-ai-agent-wizard-dot  "></span><span class="gratis-ai-agent-wizard-dot  "></span></div></div><div class="gratis-ai-agent-wizard-body"><div class="gratis-ai-agent-wizard-welcome"><p>Gratis AI Agent is an intelligent assistant that can interact with your WordPress site using registered abilities (tools).</p><p>It can manage content, query data, run commands, and more — all through a natural chat interface. Let&#x27;s get set up!</p></div></div><div class="gratis-ai-agent-wizard-footer"><button class="gratis-ai-agent-wizard-skip" data-variant="link">Skip</button><button data-variant="primary">Next</button></div></div>"`;

exports[`OnboardingWizard snapshots matches snapshot with providers available 1`] = `"<div class="gratis-ai-agent-wizard"><div class="gratis-ai-agent-wizard-header"><h2>Welcome to Gratis AI Agent</h2><div class="gratis-ai-agent-wizard-progress"><span class="gratis-ai-agent-wizard-dot is-active "></span><span class="gratis-ai-agent-wizard-dot  "></span><span class="gratis-ai-agent-wizard-dot  "></span><span class="gratis-ai-agent-wizard-dot  "></span><span class="gratis-ai-agent-wizard-dot  "></span></div></div><div class="gratis-ai-agent-wizard-body"><div class="gratis-ai-agent-wizard-welcome"><p>Gratis AI Agent is an intelligent assistant that can interact with your WordPress site using registered abilities (tools).</p><p>It can manage content, query data, run commands, and more — all through a natural chat interface. Let&#x27;s get set up!</p></div></div><div class="gratis-ai-agent-wizard-footer"><button class="gratis-ai-agent-wizard-skip" data-variant="link">Skip</button><button data-variant="primary">Next</button></div></div>"`;
