{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "meta": {
    "title": "AI Agent",
    "description": "Agentic AI assistant for WordPress — chat, call tools, run automations, and manage your site with any AI provider.",
    "author": "Ultimate-Multisite",
    "categories": ["AI", "Automation", "Chat"]
  },
  "landingPage": "/wp-admin/admin.php?page=sd-ai-agent",
  "login": {
    "username": "admin",
    "password": "password"
  },
  "preferredVersions": {
    "php": "8.2",
    "wp": "nightly"
  },
  "features": {
    "networking": true
  },
  "steps": [
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "url",
        "url": "https://github.com/Ultimate-Multisite/sd-ai-agent/releases/latest/download/sd-ai-agent.zip",
        "caption": "Downloading AI Agent..."
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "wordpress.org/plugins",
        "slug": "ai-provider-for-openai"
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "wordpress.org/plugins",
        "slug": "ai-provider-for-anthropic"
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "wordpress.org/plugins",
        "slug": "ai-provider-for-google"
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "url",
        "url": "https://github.com/Ultimate-Multisite/ai-provider-for-anthropic-max/releases/latest/download/ai-provider-for-anthropic-max.zip",
        "caption": "Downloading AI Provider for Anthropic Max..."
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "url",
        "url": "https://github.com/Ultimate-Multisite/ultimate-ai-connector-compatible-endpoints/releases/latest/download/ultimate-ai-connector-compatible-endpoints.zip",
        "caption": "Downloading AI Provider for Any Compatible Endpoint..."
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "setSiteOptions",
      "options": {
        "blogname": "AI Agent Demo",
        "blogdescription": "WordPress AI Agent — instant demo"
      }
    },
    {
      "step": "wp-cli",
      "command": "wp user update admin --display_name='Demo Admin' --user_email=demo@example.com"
    },
    {
      "step": "runPHP",
      "code": "<?php require '/wordpress/wp-load.php'; update_option('sd_ai_agent_settings', array_merge((array) get_option('sd_ai_agent_settings', []), ['_demo_note' => 'Add your API key under Tools > AI Agent Settings > General to start chatting.'])); echo 'Demo settings applied.'; ?>"
    }
  ]
}
