{
	"name": "ultimate-multisite/ai-agent",
	"description": "Agentic AI loop for WordPress — chat with an AI that can call WordPress abilities (tools) autonomously.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Ultimate Multisite Community",
			"homepage": "https://ultimatemultisite.com"
		}
	],
	"require": {
		"php": ">=8.2",
		"automattic/jetpack-autoloader": "^3.0 || ^4.0 || ^5.0",
		"smalot/pdfparser": "^2.0",
		"wordpress/php-ai-client": "^1.3"
	},
	"require-dev": {
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"php-stubs/woocommerce-stubs": "^3.0",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"phpstan/phpstan": "^2.0",
		"phpunit/phpunit": "^9.6 || ^10.0",
		"squizlabs/php_codesniffer": "^3.7",
		"szepeviktor/phpstan-wordpress": "^2.0",
		"wp-coding-standards/wpcs": "^3.0",
		"yoast/phpunit-polyfills": "^3.0"
	},
	"autoload": {
		"psr-4": {
			"GratisAiAgent\\": "includes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"GratisAiAgent\\Tests\\": "tests/GratisAiAgent/"
		}
	},
	"config": {
		"allow-plugins": {
			"automattic/jetpack-autoloader": true,
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"php-http/discovery": true
		},
		"platform": {
			"php": "8.2.0"
		},
		"preferred-install": "dist",
		"sort-packages": true
	},
	"scripts": {
		"phpcs": "vendor/bin/phpcs",
		"phpcbf": "vendor/bin/phpcbf",
		"phpstan": "vendor/bin/phpstan analyse",
		"test": "vendor/bin/phpunit",
		"lint": ["@phpcs", "@phpstan"]
	},
	"homepage": "https://github.com/Ultimate-Multisite/gratis-ai-agent",
	"support": {
		"issues": "https://github.com/Ultimate-Multisite/gratis-ai-agent/issues",
		"source": "https://github.com/Ultimate-Multisite/gratis-ai-agent"
	}
}
