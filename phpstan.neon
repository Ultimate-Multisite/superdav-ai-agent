includes:
	- vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
	level: 10
	paths:
		- includes
		- gratis-ai-agent.php
	excludePaths:
		- includes/CLI
	bootstrapFiles:
		- vendor/autoload.php
	scanFiles:
		- vendor/php-stubs/woocommerce-stubs/woocommerce-stubs.php
	treatPhpDocTypesAsCertain: false
	reportUnmatchedIgnoredErrors: false
	ignoreErrors:
		# WP_CLI is only available when running in CLI context
		- '#Call to static method .* on an unknown class WP_CLI#'
		# Constants defined at runtime (plugin_dir_url/plugin_dir_path return string at runtime)
		- '#Constant GRATIS_AI_AGENT_.* not found#'
		# GRATIS_AI_AGENT_URL/DIR are string constants defined at runtime; PHPStan sees them as mixed
		- '#Binary operation "\." between mixed and .* results in an error#'
		- '#Binary operation "\." between .* and mixed results in an error#'
		# WordPress functions that may not be stubbed
		- '#Function _wp_connectors_get_real_api_key not found#'
		# WP 7.0 AI Client SDK — provided by WordPress core at runtime, not in stubs
		# wp_ai_client_prompt() returns a PromptBuilder but PHPStan sees it as mixed
		- '#Function wp_ai_client_prompt not found#'
		- '#unknown class WP_AI_Client_Prompt_Builder#'
		- '#Instantiated class WP_AI_Client_Prompt_Builder not found#'
		- '#has invalid return type WP_AI_Client_Prompt_Builder#'
		- '#Call to method .* on an unknown class WP_AI_Client_Prompt_Builder#'
		- '#PHPDoc tag .* contains unknown class WP_AI_Client_Prompt_Builder#'
		- '#Parameter .* has invalid type WP_AI_Client_Prompt_Builder#'
		# wp_ai_client_prompt() return type is mixed until WP stubs include it;
		# callers chain methods on the result which PHPStan cannot type-check
		- '#Cannot call method (using_system_instruction|using_temperature|using_candidate_count|using_model_preference|using_model|using_provider|using_abilities|using_max_tokens|with_history|with_file|generate_text|generate_texts|generate_text_result|as_json_response)\(\) on mixed#'
		- message: '#Method .*AgentLoop::send_prompt\(\) should return .* but returns mixed#'
		  identifier: return.type
		# Compat layer classes loaded conditionally (kept for reportUnmatchedIgnoredErrors: false)
		- '#unknown class WP_AI_Client_Ability_Function_Resolver#'
		- '#Instantiated class WP_AI_Client_Ability_Function_Resolver not found#'
		- '#has invalid return type WP_AI_Client_Ability_Function_Resolver#'
		# WP AI Client SDK — wp_ai_client_prompt() and WP_AI_Client_Prompt_Builder are
		# WordPress 7.0+ core functions/classes not available in PHPStan stubs. The compat
		# layer stubs were removed when WP 6.9 support was dropped; suppress until upstream
		# phpstan-wordpress provides stubs for the WP 7.0 AI Client SDK.
		- '#Function wp_ai_client_prompt not found#'
		- '#Call to method .* on an unknown class WP_AI_Client_Prompt_Builder#'
		- '#PHPDoc tag @var for variable .* contains unknown class WP_AI_Client_Prompt_Builder#'
		- '#has invalid type WP_AI_Client_Prompt_Builder#'
		- '#Parameter \$builder of method .* has invalid type WP_AI_Client_Prompt_Builder#'
		# WordPress\AiClient\* SDK — the php-ai-client package was removed from vendor/ in
		# commit 7b10461 (issue #769) because WordPress 7.0 bundles it as a core component.
		# PHPStan cannot resolve these classes without the vendor stubs; suppress all errors
		# for the WordPress\AiClient namespace until phpstan-wordpress provides core stubs.
		- '#unknown class WordPress\\AiClient\\#'
		- '#Instantiated class WordPress\\AiClient\\#'
		- '#Class WordPress\\AiClient\\#'
		- '#has invalid type WordPress\\AiClient\\#'
		- '#Call to (method|static method) .* on an unknown class WordPress\\AiClient\\#'
		- '#PHPDoc tag .* contains unknown class WordPress\\AiClient\\#'
		- '#Parameter .* has invalid type WordPress\\AiClient\\#'
		- '#Parameter .* of method .* has invalid type WordPress\\AiClient\\#'
		- '#Parameter .* of anonymous function has invalid type WordPress\\AiClient\\#'
		- '#Property .* has unknown class WordPress\\AiClient\\#'
		- '#Property .* \(.*WordPress\\AiClient\\.*\) does not accept#'
		- '#Method .* has invalid return type WordPress\\AiClient\\#'
		- '#Method .* should return .* WordPress\\AiClient\\#'
		- '#expects WordPress\\AiClient\\#'
		# Secondary effects: when WordPress\AiClient\* classes are unknown, enum cases
		# become class-string|object and registry calls return mixed — suppress cascades.
		- '#Cannot access property \$value on class-string\|object#'
		- '#Cannot call method (getValue|getText|getType|getFunctionCall|getFunctionResponse)\(\) on class-string\|object#'
		- '#Cannot call static method (metadata|modelMetadataDirectory)\(\) on mixed#'
		# wp_ai_client_prompt() returns mixed (no stubs); method chains on the builder are safe
		- '#Cannot call method .* on mixed#'
		# Return type inferred as mixed when wp_ai_client_prompt() result is returned directly
		- '#Method .* should return .* but returns mixed#'
		# array_map with typed Closure on mixed array (result of wp_ai_client_prompt())
		- message: '#\$callback of function array_map expects \(callable\(mixed\): mixed\)\|null, Closure\(string\): string given#'
		  identifier: argument.type
		# AdminPage class was deleted in t146 (dead code removal); ScreenMetaPanel still
		# references AdminPage::SLUG — suppress until the reference is cleaned up.
		- '#Access to constant SLUG on an unknown class GratisAiAgent\\\\Admin\\\\AdminPage#'
		# WP_Block_Type properties may be empty strings
		- '#Property WP_Block_Type::.* on left side of \?\? is not nullable#'
		- '#Property WP_Block_Template::.* on left side of \?\? is not nullable#'
		# Regex match arrays - offset may not exist
		- '#Offset 1 on array.* on left side of \?\? always exists#'
		# empty() on variables that may be reassigned
		- '#Variable \$lines in empty\(\) always exists and is not falsy#'
		# Action callbacks can return values (ignored by WP)
		- '#Action callback returns .* but should not return anything#'
		# wpdb::get_row() returns object|null; properties are accessed via the WordPress
		# stdClass row pattern throughout the codebase. All callers guard against null
		# before accessing properties, so these are safe.
		- '#Access to an undefined property object::\$#'
		# Casting mixed DB row values to scalar types is safe — all values come from
		# typed database columns. PHPStan cannot infer column types from stdClass.
		- '#Cannot cast mixed to int#'
		- '#Cannot cast mixed to string#'
		- '#Cannot cast mixed to float#'
		# wpdb::prepare() requires a literal-string template; our SQL strings are
		# built from trusted internal constants and table names, not user input.
		- message: '#\$query of method wpdb::prepare\(\) expects literal-string#'
		  identifier: argument.type
		# wpdb::query() expects string but prepare() returns string|null; callers
		# always pass the result of prepare() which is non-null when called correctly.
		- message: '#\$query of method wpdb::query\(\) expects string, string\|null given#'
		  identifier: argument.type
		# json_decode() expects string; DB row fields are always stored as JSON strings.
		- message: '#\$json of function json_decode expects string, mixed given#'
		  identifier: argument.type
		# sprintf() with mixed values from DB rows — values are always scalar at runtime.
		- message: '#\$values of function sprintf expects bool\|float\|int\|string\|null, mixed given#'
		  identifier: argument.type
		# String functions with mixed values from DB rows — values are always strings at runtime.
		- message: '#\$string of function str_word_count expects string, mixed given#'
		  identifier: argument.type
		- message: '#\$string of function substr expects string, mixed given#'
		  identifier: argument.type
		- message: '#\$string of function strlen expects string, mixed given#'
		  identifier: argument.type
		- message: '#\$string of function explode expects string, mixed given#'
		  identifier: argument.type
		# WordPress sanitization functions with mixed values from request params
		- message: '#expects string, mixed given#'
		  identifier: argument.type
		# array_map/foreach with list<object>|null — callers use ?: [] guard at runtime
		- message: '#\$array of function array_map expects array, (list<object>|null|mixed) given#'
		  identifier: argument.type
		- message: '#Argument of an invalid type (list<object>|null|mixed) supplied for foreach#'
		  identifier: foreach.nonIterable
		# Accessing offsets on mixed values from DB rows and request params
		- '#Cannot access offset .* on mixed#'
		- '#Possibly invalid array key type mixed#'
		# Accessing properties on mixed values from DB rows
		- '#Cannot access property \$[a-z_]+ on mixed#'
		# method_exists() with mixed — safe pattern for optional method detection
		- message: '#\$object_or_class of function method_exists expects object\|string, mixed given#'
		  identifier: argument.type
		# count() with mixed — safe when guarded by is_array() check
		- message: '#\$value of function count expects array\|Countable, mixed given#'
		  identifier: argument.type
		# in_array() with mixed haystack — safe when value is from trusted source
		- message: '#\$haystack of function in_array expects array, mixed given#'
		  identifier: argument.type
		# Missing iterable value types — acceptable for internal methods and WordPress API types
		- '#has no value type specified in iterable type#'
		# CaseInsensitiveDictionary|array union — array type is from WordPress stubs
		- '#has parameter \$headers with no value type specified in iterable type#'
		# list<object>|null from get_results() passed to array functions — callers guard with ?: []
		- message: '#\$array of function array_map expects array, list<object>\|null given#'
		  identifier: argument.type
		- message: '#Argument of an invalid type list<object>\|null supplied for foreach#'
		  identifier: foreach.nonIterable
		- message: '#Argument of an invalid type list<stdClass>\|null supplied for foreach#'
		  identifier: foreach.nonIterable
		- message: '#\$value of function count expects array\|Countable, list<object>\|null given#'
		  identifier: argument.type
		# array from get_params() passed to methods expecting array<string, mixed> — safe at runtime
		- message: '#expects array<string, mixed>, array given#'
		  identifier: argument.type
		# array<mixed, mixed> from json_decode/get_params passed to typed array parameters — safe at runtime
		- message: '#expects array<string, mixed>, array<mixed, mixed> given#'
		  identifier: argument.type
		- message: '#expects array<string, mixed>, array<mixed> given#'
		  identifier: argument.type
		# implode() with array<mixed, mixed> — values are always strings at runtime
		- message: '#\$array of function implode expects array<string>, array<mixed, mixed> given#'
		  identifier: argument.type
		# absint() with mixed — safe when value is from trusted source
		- message: '#\$maybeint of function absint expects#'
		  identifier: argument.type
		# gmdate() with mixed timestamp — safe when value is from trusted source
		- message: '#\$timestamp of function gmdate expects int\|null, mixed given#'
		  identifier: argument.type
		# serialize_block() with mixed attrs — safe when value is from trusted source
		- message: '#\$block of function serialize_block expects#'
		  identifier: argument.type
		# array_chunk/implode with mixed — safe when value is from trusted source
		- message: '#\$array of function array_chunk expects array, mixed given#'
		  identifier: argument.type
		- message: '#\$array of function implode expects array, mixed given#'
		  identifier: argument.type
		# array_map with typed Closure callbacks — safe, PHP coerces types at runtime
		- message: '#\$callback of function array_map expects \(callable\(mixed\): mixed\)\|null, .strtolower. given#'
		  identifier: argument.type
		- message: '#\$callback of function array_map expects \(callable\(mixed\): mixed\)\|null, Closure\(string\): string given#'
		  identifier: argument.type
		# get_posts() with mixed args — safe when value is from trusted source
		- message: '#\$args of function get_posts expects array#'
		  identifier: argument.type
		# wp_update_post() with mixed postarr — safe when value is from trusted source
		- message: '#\$postarr of function wp_update_post expects array#'
		  identifier: argument.type
		# wpdb::insert() format array — safe when value is from trusted source
		- message: '#\$format of method wpdb::insert\(\) expects array<string>\|string\|null#'
		  identifier: argument.type
		# WP 7.0+ AI Client SDK — wp_ai_client_prompt() and WP_AI_Client_Prompt_Builder are
		# runtime-provided by WordPress 7.0+. PHPStan cannot resolve them from vendor stubs
		# because the SDK ships as a WordPress core component, not a standalone Composer package.
		- '#Function wp_ai_client_prompt not found#'
		- '#unknown class WP_AI_Client_Prompt_Builder#'
		- '#Instantiated class WP_AI_Client_Prompt_Builder not found#'
		- '#has invalid type WP_AI_Client_Prompt_Builder#'
		- '#PHPDoc tag `@var` for variable \$builder contains unknown class WP_AI_Client_Prompt_Builder#'
		- '#Call to method .* on an unknown class WP_AI_Client_Prompt_Builder#'
		- '#Parameter \$builder of method .* has invalid type WP_AI_Client_Prompt_Builder#'
		# wp_ai_client_prompt() returns mixed (unresolved WP 7.0 SDK type) — all callers chain
		# fluent builder methods on the result; safe at runtime when WP 7.0+ is present.
		- '#Cannot call method using_system_instruction\(\) on mixed#'
		- '#Cannot call method using_temperature\(\) on mixed#'
		- '#Cannot call method using_candidate_count\(\) on mixed#'
		- '#Cannot call method using_model_preference\(\) on mixed#'
		- '#Cannot call method using_model\(\) on mixed#'
		- '#Cannot call method using_provider\(\) on mixed#'
		- '#Cannot call method using_max_tokens\(\) on mixed#'
		- '#Cannot call method using_abilities\(\) on mixed#'
		- '#Cannot call method with_history\(\) on mixed#'
		- '#Cannot call method with_file\(\) on mixed#'
		- '#Cannot call method generate_text\(\) on mixed#'
		- '#Cannot call method generate_texts\(\) on mixed#'
		- '#Cannot call method generate_text_result\(\) on mixed#'
		- '#Cannot call method as_json_response\(\) on mixed#'
		# send_prompt() returns the result of the WP AI Client SDK chain — mixed at analysis time
		- '#Method GratisAiAgent\\Core\\AgentLoop::send_prompt\(\) should return .* but returns mixed#'
		# array_map with typed Closure on mixed-typed array — safe at runtime
		# Note: cannot use #1 in pattern (# is the PCRE delimiter); match broadly on the identifier instead
		- message: '#\$callback of function array_map expects \(callable\(mixed\): mixed\)\|null, Closure\(string\): string given#'
		  identifier: argument.type
		# GratisAiAgent\Admin\AdminPage — referenced in ScreenMetaPanel for SLUG constant;
		# class was removed/renamed but the reference remains. Suppress until class is restored.
		- '#Access to constant SLUG on an unknown class GratisAiAgent\\Admin\\AdminPage#'


